    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "test": "pnpm lint && pnpm test:types"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.73",
    "@ai-sdk/mcp": "^1.0.38",
    "@ai-sdk/vue": "^3.0.172",
    "@libsql/client": "^0.17.3",
    "@nuxt/a11y": "1.0.0-alpha.1",
    "@nuxt/content": "3.13.0",
    "@nuxt/eslint": "1.15.2",
    "@nuxt/ui": "4.7.1",
    "@nuxtjs/mcp-toolkit": "^0.15.0",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "ai": "^6.0.172",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.45.2",
    "eslint": "^10.2.1",
    "evlog": "^2.14.1",
    "feed": "^5.2.1",
    "nuxt": "^4.4.4",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6",
    "zod": "^4.4.1"
