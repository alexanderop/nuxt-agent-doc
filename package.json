  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/test-utils": "^4.0.3",
    "@playwright/test": "^1.59.1",
    "drizzle-kit": "^0.31.10",
    "eslint-plugin-oxlint": "^1.62.0",
    "lefthook": "^1.13.6",
    "oxlint": "^1.62.0",
    "vue-tsc": "^2.2.12"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "better-sqlite3",
      "esbuild",
