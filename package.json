{
  "name": "nuxt-agent-doc",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "oxlint && eslint . --cache",
    "lint:fast": "oxlint",
    "lint:eslint": "eslint . --cache",
    "typecheck": "nuxt typecheck",
