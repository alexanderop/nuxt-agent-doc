{
  "name": "nuxt-agent-doc",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint . --cache",
    "lint:fast": "oxlint",
    "typecheck": "nuxt typecheck",
    "test:types": "vue-tsc -b --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "eval": "evalite",
    "test": "pnpm lint && pnpm test:types"
  },
  "dependencies": {
    "@nuxt/a11y": "1.0.0-alpha.1",
    "@nuxt/content": "3.13.0",
    "@nuxt/eslint": "1.15.2",
    "@nuxt/ui": "4.7.1",
    "better-sqlite3": "^12.9.0",
    "eslint": "^10.2.1",
    "feed": "^5.2.1",
    "nuxt": "^4.4.4",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3",
    "vue": "^3.5.33",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/test-utils": "^4.0.3",
    "@playwright/test": "^1.59.1",
    "lefthook": "^1.13.6",
    "oxlint": "^1.62.0",
    "vue-tsc": "^2.2.12"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "better-sqlite3",
      "esbuild",
      "lefthook",
      "oxc-parser",
      "oxc-resolver",
      "oxlint",
      "unrs-resolver"
    ]
  }
}
