{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "eslint",
    "typescript",
    "unicorn",
    "import",
    "promise",
    "node",
    "oxc",
    "vue"
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "error",
    "nursery": "off",
    "pedantic": "off",
    "style": "off",
    "restriction": "off"
  },
  "rules": {
    "no-debugger": "error",
    "no-console": ["error", { "allow": ["warn", "error"] }]
  },
  "ignorePatterns": [".nuxt/**", ".output/**", "node_modules/**", "dist/**"]
}
